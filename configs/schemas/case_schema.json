{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SaunaFlow Case Definition",
  "description": "YAML/JSON schema for sauna CFD case configuration",
  "type": "object",
  "required": ["case", "geometry", "boundary_conditions", "solver"],
  "properties": {
    "case": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique case identifier"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["steady", "transient"],
          "default": "steady"
        }
      },
      "additionalProperties": false
    },
    "geometry": {
      "type": "object",
      "required": ["dimensions"],
      "properties": {
        "dimensions": {
          "type": "object",
          "required": ["x", "y", "z"],
          "properties": {
            "x": { "type": "number", "exclusiveMinimum": 0 },
            "y": { "type": "number", "exclusiveMinimum": 0 },
            "z": { "type": "number", "exclusiveMinimum": 0 }
          },
          "additionalProperties": false
        },
        "mesh_level": {
          "type": "string",
          "enum": ["M0", "M1", "M2", "M3"],
          "default": "M0",
          "description": "M0=2D coarse, M1=simple 3D, M2=PoC, M3=fine"
        }
      },
      "additionalProperties": false
    },
    "boundary_conditions": {
      "type": "object",
      "properties": {
        "walls": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number" },
            "type": { "type": "string", "enum": ["fixed", "adiabatic", "mixed"] },
            "model": { "type": "string", "enum": ["fixed", "lumped"], "default": "fixed", "description": "Wall thermal model: fixed=constant T, lumped=wall heats up" },
            "thickness": { "type": "number", "exclusiveMinimum": 0, "default": 0.015, "description": "Wall panel thickness [m]" },
            "conductivity": { "type": "number", "exclusiveMinimum": 0, "default": 0.12, "description": "Wall thermal conductivity [W/(m*K)]" },
            "rho_cp": { "type": "number", "exclusiveMinimum": 0, "default": 500000, "description": "Wall volumetric heat capacity [J/(m3*K)]" },
            "wall_htc_override": { "type": "number", "exclusiveMinimum": 0, "description": "Override wall heat transfer coefficient [W/(m2*K)]. If set, ignores thickness/conductivity calculation." }
          },
          "additionalProperties": false
        },
        "heater": {
          "type": "object",
          "required": ["power_kw", "position"],
          "properties": {
            "power_kw": { "type": "number", "exclusiveMinimum": 0 },
            "position": {
              "type": "object",
              "required": ["x", "y", "z"],
              "properties": {
                "x": {
                  "type": "number",
                  "const": 0,
                  "description": "Phase 1 heater is mounted on the x=0 wall"
                },
                "y": { "type": "number" },
                "z": { "type": "number" }
              },
              "additionalProperties": false
            },
            "width": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 0.5,
              "description": "Heater width in meters (z-direction)"
            },
            "height": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 0.5,
              "description": "Heater height in meters (y-direction)"
            },
            "model": {
              "type": "string",
              "enum": ["surface_flux", "volume_source"],
              "default": "surface_flux",
              "description": "Heater model: surface_flux (wall heat flux BC) or volume_source (fvOptions in cellZone)"
            },
            "depth": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 0.3,
              "description": "Heater depth in x-direction [m] (used for volume_source cellZone)"
            },
            "wall_fixed_T": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Fixed heater wall temperature [K]. Overrides heater_wall BC to fixedValue."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "solver": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["buoyantSimpleFoam", "buoyantPimpleFoam"],
          "description": "OpenFOAM solver to use"
        },
        "end_time": { "type": "number", "exclusiveMinimum": 0 },
        "write_interval": { "type": "number", "exclusiveMinimum": 0 },
        "delta_t": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Time step for transient solvers [s]"
        },
        "max_delta_t": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum time step for adjustTimeStep [s]"
        },
        "averaging_start": {
          "type": "number",
          "minimum": 0,
          "description": "Start time for field averaging [s]"
        },
        "mixture": {
          "type": "string",
          "enum": ["pure", "multiComponent"],
          "default": "pure",
          "description": "Thermophysical mixture type"
        },
        "uniform_init": {
          "type": "boolean",
          "default": false,
          "description": "Use uniform initial fields (skip 2-zone plume initialization)"
        }
      },
      "additionalProperties": false
    },
    "loyly": {
      "type": "object",
      "properties": {
        "water_ml": {"type": "number", "minimum": 0, "description": "Water amount in mL"},
        "time": {"type": "number", "minimum": 0, "description": "Time when water is poured [s]"},
        "tau_evap": {"type": "number", "minimum": 0.1, "default": 5.0, "description": "Evaporation time constant [s]"}
      },
      "required": ["water_ml"],
      "additionalProperties": false
    },
    "probes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "position"],
        "properties": {
          "name": { "type": "string" },
          "position": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "additionalProperties": false
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["T"]
          }
        },
        "additionalProperties": false
      }
    },
    "ventilation": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["none", "supply_exhaust"],
          "default": "none",
          "description": "Ventilation model: none=sealed room, supply_exhaust=supply+exhaust vents"
        },
        "T_ambient": {
          "type": "number",
          "description": "Ambient air temperature at supply vent [K]",
          "default": 293.15
        },
        "w_ambient": {
          "type": "number",
          "minimum": 0,
          "default": 0.005,
          "description": "Ambient humidity ratio [kg vapor/kg dry air]"
        },
        "supply": {
          "type": "object",
          "properties": {
            "height": {"type": "number", "minimum": 0, "description": "Supply vent height [m]"},
            "area": {"type": "number", "exclusiveMinimum": 0, "description": "Supply vent area [m2]"},
            "Cd": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.6, "description": "Discharge coefficient"}
          },
          "required": ["height", "area"],
          "additionalProperties": false
        },
        "exhaust": {
          "type": "object",
          "properties": {
            "height": {"type": "number", "minimum": 0, "description": "Exhaust vent height [m]"},
            "area": {"type": "number", "exclusiveMinimum": 0, "description": "Exhaust vent area [m2]"},
            "Cd": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.6, "description": "Discharge coefficient"}
          },
          "required": ["height", "area"],
          "additionalProperties": false
        }
      },
      "required": ["model"],
      "additionalProperties": false
    },
    "aufguss": {
      "type": "object",
      "properties": {
        "beta_aug": {"type": "number", "minimum": 0, "description": "Forced mixing coefficient [kg/s] from CFD ROM"},
        "start_time": {"type": "number", "minimum": 0, "description": "Aufguss start time [s]"},
        "duration": {"type": "number", "minimum": 0, "default": 30.0, "description": "Aufguss duration [s]"},
        "jet_velocity": {"type": "number", "minimum": 0, "default": 2.0, "description": "Jet velocity for OpenFOAM momentum source [m/s]"}
      },
      "required": ["beta_aug"],
      "additionalProperties": false
    },
    "radiation": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["none", "viewFactor", "fvDOM"],
          "default": "none",
          "description": "Radiation model: none, viewFactor (wall-to-wall), fvDOM (full DOM)"
        }
      },
      "additionalProperties": false
    },
    "turbulence": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["kOmegaSST", "kOmegaSSTLM"],
          "default": "kOmegaSST",
          "description": "Turbulence model: kOmegaSST (standard) or kOmegaSSTLM (with transition)"
        },
        "convection_scheme": {
          "type": "string",
          "enum": ["linearUpwind", "vanLeer", "limitedLinear"],
          "default": "linearUpwind",
          "description": "Convection scheme for T/h: linearUpwind (2nd order) or TVD limiter"
        },
        "buoyancy_production": {
          "type": "boolean",
          "default": true,
          "description": "Enable buoyancy production source in k-equation (requires wmake for codedSource)"
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "properties": {
        "experimental_csv": {"type": "string", "description": "Path to experimental CSV"},
        "tolerances": {
          "type": "object",
          "additionalProperties": {"type": "number"},
          "description": "Per-probe tolerance in K"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
