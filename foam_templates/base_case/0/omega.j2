FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 5.0;

boundaryField
{
    "(floor|ceiling|heater_wall|heater_wall_surround|opposite_wall|front|back)"
    {
        type            omegaWallFunction;
        value           uniform 5.0;
    }
{% if ventilation | default(false) %}
    supply_vent
    {
        type            fixedValue;
        value           uniform 5.0;
    }
    exhaust_vent
    {
        type            zeroGradient;
    }
{% endif %}
}
