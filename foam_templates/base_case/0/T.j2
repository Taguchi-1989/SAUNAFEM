FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

dimensions      [0 0 0 1 0 0 0];

internalField   uniform {{ T_initial }};

boundaryField
{
{% if radiation_model | default("none") != "none" %}
    // Radiation fields handled by radiation model
{% endif %}
    floor
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }

    ceiling
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }

    heater_wall
    {
        type            fixedValue;
        value           uniform {{ T_heater | default(473.15) }};
    }

    heater_wall_surround
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }

    opposite_wall
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }

    front
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }

    back
    {
        type            fixedValue;
        value           uniform {{ T_wall_inner | default(T_walls) }};
    }
{% if ventilation | default(false) %}
    supply_vent
    {
        type            inletOutlet;
        inletValue      uniform {{ T_ambient | default(293.15) }};
        value           uniform {{ T_ambient | default(293.15) }};
    }
    exhaust_vent
    {
        type            inletOutlet;
        inletValue      uniform {{ T_ambient | default(293.15) }};
        value           uniform {{ T_walls }};
    }
{% endif %}
}
