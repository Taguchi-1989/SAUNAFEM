FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

convertToMeters 1;

vertices
(
{% for vertex in vertices %}
    ({{ vertex[0] }} {{ vertex[1] }} {{ vertex[2] }})  // {{ loop.index0 }}
{% endfor %}
);

blocks
(
{% for block in blocks %}
    hex ({{ block.vertices | join(' ') }}) ({{ block.cells | join(' ') }}) simpleGrading (1 1 1)
{% endfor %}
);

edges
(
);

boundary
(
    floor
    {
        type wall;
        faces
        (
{% for face in floor_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    ceiling
    {
        type wall;
        faces
        (
{% for face in ceiling_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    heater_wall
    {
        type wall;
        faces
        (
{% for face in heater_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    heater_wall_surround
    {
        type wall;
        faces
        (
{% for face in heater_surround_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    opposite_wall
    {
        type wall;
        faces
        (
{% for face in opposite_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    front
    {
        type wall;
        faces
        (
{% for face in front_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    back
    {
        type wall;
        faces
        (
{% for face in back_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
{% if ventilation | default(false) %}
    supply_vent
    {
        type patch;
        faces
        (
{% for face in supply_vent_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
    exhaust_vent
    {
        type patch;
        faces
        (
{% for face in exhaust_vent_faces %}
            ({{ face | join(' ') }})
{% endfor %}
        );
    }
{% endif %}
);

mergePatchPairs
(
);
