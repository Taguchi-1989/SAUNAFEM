FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    p_rgh
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        GaussSeidel;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    rho
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-7;
        relTol          0.1;
    }

    rhoFinal
    {
        $rho;
        relTol          0;
    }

    "(U|T|h|k|omega|epsilon)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.1;
    }

    "(U|T|h|k|omega|epsilon)Final"
    {
        $U;
        relTol          0;
    }
}

{% if solver_name == "buoyantPimpleFoam" %}
PIMPLE
{
    nOuterCorrectors    2;
    nCorrectors         1;
    nNonOrthogonalCorrectors 0;
    pRefCell            0;
    pRefValue           101325;

    residualControl
    {
        p_rgh
        {
            relTol          0;
            tolerance       1e-4;
        }
        U
        {
            relTol          0;
            tolerance       1e-4;
        }
        T
        {
            relTol          0;
            tolerance       1e-5;
        }
    }
}
{% else %}
SIMPLE
{
    nNonOrthogonalCorrectors 0;
    pRefCell        0;
    pRefValue       0;

    residualControl
    {
        p_rgh           1e-4;
        U               1e-4;
        T               1e-5;
        "(k|omega|epsilon)" 1e-4;
    }
}
{% endif %}

relaxationFactors
{
    fields
    {
        p_rgh           0.3;
    }
    equations
    {
        U               0.7;
        T               0.5;
        k               0.7;
        omega           0.7;
        epsilon         0.7;
    }
}
