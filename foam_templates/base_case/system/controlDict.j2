FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     {{ solver_name }};

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         {{ end_time }};

deltaT          {{ delta_t }};

writeControl    adjustableRunTime;

writeInterval   {{ write_interval }};

purgeWrite      5;

writeFormat     ascii;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

{% if solver_name == "buoyantPimpleFoam" %}
adjustTimeStep  yes;

maxCo           0.5;

maxDeltaT       {{ delta_t }};
{% endif %}

functions
{
    probes
    {
        type            probes;
        libs            (sampling);
        writeControl    writeTime;
        probeLocations
        (
{% for probe in probes %}
            ({{ probe.x }} {{ probe.y }} {{ probe.z }})  // {{ probe.name }}
{% endfor %}
        );
        fields
        (
            T
            U
        );
    }

    fieldAverage
    {
        type            fieldAverage;
        libs            (fieldFunctionObjects);
        writeControl    writeTime;
        timeStart       {{ averaging_start }};
        fields
        (
            T
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            U
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
        );
    }
}
