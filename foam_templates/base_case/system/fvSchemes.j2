FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

ddtSchemes
{
{% if solver_name == "buoyantPimpleFoam" %}
    default         backward;
{% else %}
    default         steadyState;
{% endif %}
}

gradSchemes
{
    default         Gauss linear;
    grad(p_rgh)     Gauss linear;
    grad(U)         cellLimited Gauss linear 1;
}

divSchemes
{
    default         none;
    div(phi,U)      bounded Gauss linearUpwind grad(U);
{% if convection_scheme | default("linearUpwind") == "vanLeer" %}
    div(phi,T)      bounded Gauss vanLeer;
    div(phi,h)      bounded Gauss vanLeer;
{% elif convection_scheme | default("linearUpwind") == "limitedLinear" %}
    div(phi,T)      bounded Gauss limitedLinear 1;
    div(phi,h)      bounded Gauss limitedLinear 1;
{% else %}
    div(phi,T)      bounded Gauss linearUpwind default;
    div(phi,h)      bounded Gauss linearUpwind default;
{% endif %}
    div(phi,k)      bounded Gauss upwind;
    div(phi,omega)  bounded Gauss upwind;
    div(phi,epsilon) bounded Gauss upwind;
    div(phi,K)      bounded Gauss linear;
    div(phi,p)      bounded Gauss linear;
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
{% if species_transport | default(false) %}
    div(phi,Yi_h)   bounded Gauss linearUpwind default;
{% endif %}
{% if radiation_model | default("none") == "fvDOM" %}
    div(Ji,Ii_h)    bounded Gauss linearUpwind default;
{% endif %}
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method          meshWave;
}
