FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvOptions;
}

{% if buoyancy_production | default(true) %}
buoyancyProduction
{
    type            scalarCodedSource;
    name            buoyancyProductionK;
    active          true;
    selectionMode   all;

    scalarCodedSourceCoeffs
    {
        selectionMode   all;
        fields          (k);

        codeInclude
        #{
            #include "fvCFD.H"
        #};

        codeCorrect
        #{
        #};

        codeAddSup
        #{
            // Buoyancy production/destruction term G_b for k-equation
            // G_b = -(mu_t / (rho * Pr_t)) * (g & grad(rho))
            // Stable stratification (hot above cold) -> suppresses turbulence
            // Unstable stratification (cold above hot) -> enhances turbulence
            // NOTE: fvc::grad(rho) is valid for multiComponentMixture too,
            // because rho already accounts for composition (Y_i) effects
            // via the equation of state in thermophysicalProperties.
            const volScalarField& rho =
                mesh_.lookupObject<volScalarField>("rho");
            const volScalarField& mut =
                mesh_.lookupObject<volScalarField>("mut");
            const uniformDimensionedVectorField& g =
                mesh_.lookupObject<uniformDimensionedVectorField>("g");
            const scalar Prt = 0.85;

            // Guard against zero density at startup
            volScalarField rhoSafe
            (
                "rhoSafe",
                max(rho, dimensionedScalar("rhoMin", rho.dimensions(), 0.5))
            );

            volScalarField Gb
            (
                "Gb",
                -(mut / (rhoSafe * Prt)) * (g & fvc::grad(rho))
            );

            // Explicit source: add Gb directly to k equation RHS.
            // Simpler and avoids division by k (which can be zero at startup).
            eqn += Gb;
        #};

        codeConstrain
        #{
        #};
    }
}
{% endif %}

{% if aufguss_enabled %}
aufgussJet
{
    type            vectorCodedSource;
    active          true;
    selectionMode   cellZone;
    cellZone        aufgussZone;

    vectorCodedSourceCoeffs
    {
        selectionMode   cellZone;
        cellZone        aufgussZone;
        fields          (U);

        codeInclude
        #{
            #include "fvCFD.H"
        #};

        codeCorrect
        #{
        #};

        codeAddSup
        #{
            // Aufguss jet: downward momentum in the aufguss zone
            // Simulates towel waving creating a directed air jet
            const scalar jetVelocity = {{ aufguss_jet_velocity }};  // m/s
            const scalar jetDirection = -1.0;  // downward (y-direction)

            vectorField& USource = eqn.source();
            const scalarField& V = mesh_.V();

            forAll(cells, i)
            {
                label cellI = cells[i];
                // Momentum source = rho * V * acceleration
                // Simplified as a body force in the y-direction
                USource[cellI][1] += jetDirection * jetVelocity * V[cellI] / {{ aufguss_duration }};
            }
        #};

        codeConstrain
        #{
        #};
    }
}
{% endif %}

{% if not (buoyancy_production | default(true)) and not aufguss_enabled %}
// No fvOptions active
{% endif %}
