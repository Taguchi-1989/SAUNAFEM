FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}

simulationType  RAS;

RAS
{
{% if turbulence_model | default("kOmegaSST") == "kOmegaSSTLM" %}
    RASModel        kOmegaSSTLM;
{% else %}
    RASModel        kOmegaSST;
{% endif %}
    turbulence      on;
    printCoeffs     on;

    // Prevent excessive turbulence decay in buoyancy-driven flows
    // kMin sets a floor on turbulent kinetic energy to maintain mixing
    kMin            0.01;
}
