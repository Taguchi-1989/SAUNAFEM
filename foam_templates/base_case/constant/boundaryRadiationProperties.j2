FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      boundaryRadiationProperties;
}

{% if radiation_model | default("none") != "none" %}
// Emissivity for each wall patch
// Wood paneling: epsilon ~0.9
// Heater surface (cast iron/stone): epsilon ~0.85

floor
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

ceiling
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

heater_wall
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.85;
        emissivity      0.85;
    }
}

heater_wall_surround
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

opposite_wall
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

front
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

back
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.9;
        emissivity      0.9;
    }
}

{% if ventilation | default(false) %}
supply_vent
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.0;
        emissivity      0.0;
    }
}

exhaust_vent
{
    type        opaqueDiffusive;
    wallAbsorptionEmissionModel
    {
        type            constantAbsorption;
        absorptivity    0.0;
        emissivity      0.0;
    }
}
{% endif %}

{% else %}
// Radiation model disabled - no boundary radiation properties needed
{% endif %}
